{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kakeibot",
  "main": "./workers/app.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client"
  },
  "alias": {
    "virtual:react-router/server-build": "./dist/server/index.js"
  }
}
