{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kakeibot",
  "main": "./workers/app.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client"
  },
  "alias": {
    "virtual:react-router/server-build": "./dist/server/index.js"
  },
  // 本番の非秘匿変数（秘匿値は wrangler secret put で別途登録）
  "vars": {
    "USE_MOCK_LINE": "false",
    "USE_MOCK_AI": "false",
    "USE_MOCK_STORAGE": "false",
    "USE_MOCK_AUTH": "false",
    "GEMINI_MODEL": "gemini-2.5-flash-lite",
    "APP_BASE_URL": "https://kakeibot.yotarotsukada.workers.dev"
  },
  "env": {
    // プレビュー環境（PR ごとの Worker にも適用）
    // 秘匿値: SPREADSHEET_ID / GOOGLE_SERVICE_ACCOUNT_EMAIL / GOOGLE_PRIVATE_KEY
    //         は GitHub Actions から wrangler secret put で注入する
    "preview": {
      "vars": {
        "USE_MOCK_LINE": "true",
        "USE_MOCK_AI": "true",
        "USE_MOCK_STORAGE": "false",
        "USE_MOCK_AUTH": "true",
        "GEMINI_MODEL": "gemini-2.5-flash-lite",
        // LINE / AI がモックのため下記はダミー値で問題ない
        "JWT_SECRET": "preview-not-a-real-secret",
        "APP_BASE_URL": "https://preview.example.com",
        "LINE_LOGIN_CALLBACK_URL": "https://preview.example.com/auth/callback",
        "LINE_CHANNEL_SECRET": "preview-mock",
        "LINE_CHANNEL_ACCESS_TOKEN": "preview-mock",
        "LINE_LOGIN_CHANNEL_ID": "preview-mock",
        "LINE_LOGIN_CHANNEL_SECRET": "preview-mock",
        "GEMINI_API_KEY": "preview-mock"
      }
    }
  }
}
